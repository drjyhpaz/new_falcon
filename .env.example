# Falcon RDP Configuration

# Attack Settings
ATTACK_THREADS=16
ATTACK_TIMEOUT=10
ATTACK_RATE_LIMIT=100

# Stealth Settings
STEALTH_ENABLED=true
STEALTH_MIN_JITTER=500
STEALTH_MAX_JITTER=2000
STEALTH_ADAPTIVE_RATE=true

# Proxy Settings
PROXY_ENABLED=false
PROXY_TYPE=socks5
PROXY_FILE=proxies.txt
PROXY_ROTATION=true

# Lockout Prevention
LOCKOUT_THRESHOLD=3
LOCKOUT_COOLDOWN=60

# Resume Settings
RESUME_ENABLED=true
CHECKPOINT_INTERVAL=100

# TLS Settings
INSECURE_TLS=false
NLA_DETECTION=true

# Logging
LOG_LEVEL=info
LOG_FILE=logs/falcon.log
